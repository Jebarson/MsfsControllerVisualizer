<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Msfs.ControllerVisualizer.Converters;assembly=Msfs.ControllerVisualizer">

    <UserControl.Resources>

        <!-- Joystick Button Mapping Converters -->
        <converters:JoystickButtonMappingConverter x:Key="JoystickButtonMappingConverter" />
        <converters:JoystickButtonTruncateConverter x:Key="JoystickButtonTruncateConverter" MaxLength="20" />

        <!-- Ellipse Styles -->
        <Style x:Key="GripEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="300" />
        </Style>

        <Style x:Key="HatEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
        </Style>

        <Style x:Key="CenterHubEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Width" Value="300" />
            <Setter Property="Height" Value="190" />
        </Style>

        <Style x:Key="IgnitionDialEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="120" />
        </Style>

        <!-- Rectangle Styles -->
        <Style x:Key="SwitchPanelRectangleStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Width" Value="450" />
            <Setter Property="Height" Value="260" />
        </Style>

        <!-- Button Styles -->
        <Style x:Key="StandardButtonStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <Style x:Key="WhiteButtonStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Fill" Value="#ffffff" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <Style x:Key="RedButtonStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Fill" Value="#c0392b" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <!-- Text Styles -->
        <Style x:Key="ButtonNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="WhiteButtonNumberStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonNumberStyle}">
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style x:Key="RedButtonNumberStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonNumberStyle}">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="ButtonBindingRightStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="ButtonBindingLeftStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style x:Key="ButtonBindingBottomStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="DirectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="FontSize" Value="9" />
        </Style>

        <Style x:Key="DirectionBindingStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="8" />
        </Style>

        <Style x:Key="SwitchNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style x:Key="SwitchBindingStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="8" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MaxHeight" Value="24" />
            <Setter Property="Margin" Value="2" />
        </Style>

        <Style x:Key="AxisLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="AxisBindingStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="9" />
        </Style>

        <Style x:Key="IgnitionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="IgnitionBindingStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22" />
            <Setter Property="FontSize" Value="8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxWidth" Value="70" />
        </Style>

        <!-- Line and Shape Styles -->
        <Style x:Key="TickMarkStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <Style x:Key="AxisPathStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style x:Key="AxisLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <Style x:Key="AxisPolygonStyle" TargetType="Polygon">
            <Setter Property="Fill" Value="#D3D3D3" />
        </Style>

        <!-- Switch Styles -->
        <Style x:Key="MasterSwitchStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Fill" Value="#8B0000" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <Style x:Key="AvionicsSwitchStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Fill" Value="White" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <Style x:Key="LightSwitchStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Fill" Value="Gray" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Stroke" Value="#D3D3D3" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Margin" Value="0,2" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Canvas Width="900" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- LEFT YOKE GRIP ASSEMBLY -->
            <Canvas x:Name="LeftGripCanvas" Canvas.Left="60" Canvas.Top="20">
                <Ellipse Style="{StaticResource GripEllipseStyle}" />

                <!-- POV Hat Switch -->
                <Canvas Width="80" Height="80" Canvas.Left="60" Canvas.Top="40">
                    <Ellipse Canvas.Left="10" Canvas.Top="10" Style="{StaticResource HatEllipseStyle}" />

                    <!-- Hat Direction Tick Marks -->
                    <Line X1="40" Y1="15" X2="40" Y2="22" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="57" Y1="23" X2="53" Y2="27" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="65" Y1="40" X2="58" Y2="40" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="57" Y1="57" X2="53" Y2="53" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="40" Y1="65" X2="40" Y2="58" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="23" Y1="57" X2="27" Y2="53" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="15" Y1="40" X2="22" Y2="40" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="23" Y1="23" X2="27" Y2="27" Style="{StaticResource TickMarkStyle}" />

                    <!-- Hat Direction Labels -->
                    <TextBlock Text="U" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="34" Canvas.Top="0" />
                    <TextBlock Text="U-R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="55" Canvas.Top="5" />
                    <TextBlock Text="R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="70" Canvas.Top="32" />
                    <TextBlock Text="D-R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="55" Canvas.Top="58" />
                    <TextBlock Text="D" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="36" Canvas.Top="70" />
                    <TextBlock Text="D-L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="5" Canvas.Top="58" />
                    <TextBlock Text="L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="-5" Canvas.Top="32" />
                    <TextBlock Text="U-L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="5" Canvas.Top="5" />

                    <!-- Hat Direction Bindings -->
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Up}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Up}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="34" Canvas.Top="12" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_UpRight}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_UpRight}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="52" Canvas.Top="18" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Right}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Right}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="60" Canvas.Top="32" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_DownRight}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_DownRight}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="52" Canvas.Top="44" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Down}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Down}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="34" Canvas.Top="52" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_DownLeft}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_DownLeft}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="18" Canvas.Top="44" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Left}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Left}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="12" Canvas.Top="32" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Up_Left}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Up_Left}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="18" Canvas.Top="18" />
                </Canvas>

                <!-- Button 1: Switch -->
                <StackPanel Orientation="Horizontal" Canvas.Left="190" Canvas.Top="70">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="1" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingRightStyle}" MaxWidth="100"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_1}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_1}" />
                </StackPanel>

                <!-- Button 2: Switch -->
                <StackPanel Orientation="Horizontal" Canvas.Left="130" Canvas.Top="120">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="2" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingRightStyle}" MaxWidth="100"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_2}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_2}" />
                </StackPanel>

                <!-- Button 6: Trim Up (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="50" Canvas.Top="170">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="6" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_6}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_6}" />
                </StackPanel>

                <!-- Button 5: Trim Down (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="50" Canvas.Top="210">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="5" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_5}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_5}" />
                </StackPanel>

                <!-- Button 8: Rudder Trim Right (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="120" Canvas.Top="170">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="8" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_8}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_8}" />
                </StackPanel>

                <!-- Button 7: Rudder Trim Left (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="120" Canvas.Top="210">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="7" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_7}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_7}" />
                </StackPanel>
            </Canvas>

            <!-- CENTER HUB WITH AXIS INDICATORS -->
            <Canvas x:Name="CenterHubCanvas" Canvas.Left="300" Canvas.Top="95">
                <Ellipse Style="{StaticResource CenterHubEllipseStyle}" />

                <!-- Axis Display Area -->
                <Canvas Width="230" Height="160" Canvas.Top="15" Canvas.Left="35">
                    <!-- X Axis (Roll) Semicircle Indicator -->
                    <Path Canvas.Left="15" Canvas.Top="40" Data="M 0 50 A 50 50 0 0 1 100 50"
                            Style="{StaticResource AxisPathStyle}" />
                    <TextBlock Text="X Axis" Style="{StaticResource AxisLabelStyle}" Canvas.Left="50" Canvas.Top="95" />
                    <TextBlock Style="{StaticResource AxisBindingStyle}" Canvas.Left="50" Canvas.Top="110">
                        <TextBlock.Text>
                            <Binding Converter="{StaticResource JoystickButtonMappingConverter}"
                                     ConverterParameter="Joystick_L-Axis_X" />
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Y Axis (Pitch) Vertical Arrow Indicator -->
                    <Line X1="180" Y1="30" X2="180" Y2="120" Style="{StaticResource AxisLineStyle}" />
                    <Polygon Points="180,20 175,30 185,30" Style="{StaticResource AxisPolygonStyle}" />
                    <Polygon Points="180,130 175,120 185,120" Style="{StaticResource AxisPolygonStyle}" />
                    <TextBlock Text="Y Axis" Style="{StaticResource AxisLabelStyle}" Canvas.Left="170" Canvas.Top="135" />
                    <TextBlock Style="{StaticResource AxisBindingStyle}" Canvas.Left="170" Canvas.Top="150">
                        <TextBlock.Text>
                            <Binding Converter="{StaticResource JoystickButtonMappingConverter}"
                                     ConverterParameter="Joystick_L-Axis_Y" />
                        </TextBlock.Text>
                    </TextBlock>
                </Canvas>
            </Canvas>

            <!-- RIGHT YOKE GRIP ASSEMBLY -->
            <Canvas x:Name="RightGripCanvas" Canvas.Right="260" Canvas.Top="20">
                <Ellipse Style="{StaticResource GripEllipseStyle}" />

                <!-- Button 3: POV Hat Down -->
                <StackPanel Orientation="Horizontal" Canvas.Left="10" Canvas.Top="90">
                    <TextBlock Style="{StaticResource ButtonBindingLeftStyle}" MaxWidth="100"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_3}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_3}" />
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="3" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                </StackPanel>

                <!-- Button 4: Smoke / Special -->
                <StackPanel Canvas.Left="110" Canvas.Top="50">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource RedButtonStyle}" />
                        <TextBlock Text="4" Style="{StaticResource RedButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingLeftStyle}" MaxWidth="100"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_4}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_4}" />
                </StackPanel>

                <!-- Button 11: Rudder Trim Left (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="70" Canvas.Top="150">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="11" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_11}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_11}" />
                </StackPanel>

                <!-- Button 12: Rudder Trim Right (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="110" Canvas.Top="150">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="12" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_12}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_12}" />
                </StackPanel>

                <!-- Button 9: Trim Down (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="70" Canvas.Top="220">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="9" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_9}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_9}" />
                </StackPanel>

                <!-- Button 10: Trim Up (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="110" Canvas.Top="220">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="10" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" MaxWidth="60"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_10}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_10}" />
                </StackPanel>
            </Canvas>

            <!-- SWITCH PANEL ASSEMBLY -->
            <Canvas x:Name="SwitchPanelCanvas" Canvas.Left="60" Canvas.Top="330">
                <Rectangle Style="{StaticResource SwitchPanelRectangleStyle}" />

                <!-- Top Row: Master and Avionics Switches -->
                <UniformGrid Columns="4" Canvas.Left="20" Canvas.Top="5" Width="410" Height="130">

                    <!-- Master Alternator Switch (13-14) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="13 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_13}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_13}" />
                        <Rectangle Style="{StaticResource MasterSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="13 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_14}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_14}" />
                    </StackPanel>

                    <!-- Master Battery Switch (15-16) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="15 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_15}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_15}" />
                        <Rectangle Style="{StaticResource MasterSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="15 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
