<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="800" Height="600">
    <Canvas Background="#2D2D30">
        <!-- Main Body -->
        <Rectangle Canvas.Left="50" Canvas.Top="50" Width="700" Height="500" Fill="#3A3A3A" Stroke="#555" StrokeThickness="2" RadiusX="5" RadiusY="5"/>
        
        <!-- Toggle Switches Panel -->
        <Rectangle Canvas.Left="70" Canvas.Top="70" Width="660" Height="120" Fill="#2A2A2A" Stroke="#666" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <TextBlock Canvas.Left="330" Canvas.Top="80" Text="TOGGLE SWITCHES" FontSize="12" Foreground="#888" FontWeight="Bold"/>
        
        <!-- Top Row Toggle Switches (0-6) -->
        <Border x:Name="btn_0" Canvas.Left="80" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 0" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Battery" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_0_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_1" Canvas.Left="160" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 1" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Alternator" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_1_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_2" Canvas.Left="240" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 2" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Avionics" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_2_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_3" Canvas.Left="320" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 3" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Fuel Pump" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_3_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_4" Canvas.Left="400" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 4" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="De-Ice" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_4_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_5" Canvas.Left="480" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 5" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Pitot Heat" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_5_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_6" Canvas.Left="560" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 6" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Cowl Flaps" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_6_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_7" Canvas.Left="640" Canvas.Top="100" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 7" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Panel" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_7_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Light Switches Panel (8-12) -->
        <Rectangle Canvas.Left="70" Canvas.Top="210" Width="330" Height="120" Fill="#2A2A2A" Stroke="#666" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <TextBlock Canvas.Left="180" Canvas.Top="220" Text="LIGHTS" FontSize="12" Foreground="#888" FontWeight="Bold"/>
        
        <Border x:Name="btn_8" Canvas.Left="80" Canvas.Top="245" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 8" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Beacon" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_8_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_9" Canvas.Left="150" Canvas.Top="245" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 9" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Landing" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_9_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_10" Canvas.Left="220" Canvas.Top="245" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 10" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Taxi" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_10_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_11" Canvas.Left="290" Canvas.Top="245" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 11" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Nav" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_11_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <Border x:Name="btn_12" Canvas.Left="80" Canvas.Top="295" Background="#444" BorderBrush="#666" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="BTN 12" FontSize="8" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="Strobe" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_12_mapping" Text="[Not Mapped]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Landing Gear Lever (13) -->
        <Rectangle Canvas.Left="430" Canvas.Top="210" Width="300" Height="120" Fill="#2A2A2A" Stroke="#666" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <TextBlock Canvas.Left="530" Canvas.Top="220" Text="LANDING GEAR" FontSize="12" Foreground="#888" FontWeight="Bold"/>
        
        <Border x:Name="btn_13" Canvas.Left="510" Canvas.Top="250" Background="#660000" BorderBrush="#AA0000" BorderThickness="2" CornerRadius="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Button 13" FontSize="10" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock Text="GEAR LEVER" FontSize="12" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="btn_13_mapping" Text="[Not Mapped]" FontSize="12" Foreground="#4EC9B0" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Throttle Levers Area -->
        <Rectangle Canvas.Left="70" Canvas.Top="350" Width="660" Height="180" Fill="#2A2A2A" Stroke="#666" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <TextBlock Canvas.Left="340" Canvas.Top="360" Text="THROTTLE QUADRANT" FontSize="12" Foreground="#888" FontWeight="Bold"/>
        
        <!-- Throttle Axis Indicators -->
        <Border Canvas.Left="90" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Throttle 1" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_throttle1" Text="[Axis 0]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Canvas.Left="180" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Throttle 2" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_throttle2" Text="[Axis 1]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Canvas.Left="270" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Prop 1" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_prop1" Text="[Axis 2]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Canvas.Left="350" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Prop 2" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_prop2" Text="[Axis 3]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Canvas.Left="430" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Mixture 1" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_mixture1" Text="[Axis 4]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border Canvas.Left="520" Canvas.Top="390" Background="#333" BorderBrush="#555" BorderThickness="1" CornerRadius="3" Padding="5">
            <StackPanel>
                <TextBlock Text="Mixture 2" FontSize="9" Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="axis_mixture2" Text="[Axis 5]" FontSize="10" Foreground="#4EC9B0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <!-- Visual representation of levers -->
        <Rectangle Canvas.Left="110" Canvas.Top="460" Width="20" Height="60" Fill="#555" Stroke="#777" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <Rectangle Canvas.Left="200" Canvas.Top="460" Width="20" Height="60" Fill="#555" Stroke="#777" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
        <Rectangle Canvas.Left="290" Canvas.Top="470" Width="15" Height="50" Fill="#444" Stroke="#666" StrokeThickness="1" RadiusX="2" RadiusY="2"/>
        <Rectangle Canvas.Left="370" Canvas.Top="470" Width="15" Height="50" Fill="#444" Stroke="#666" StrokeThickness="1" RadiusX="2" RadiusY="2"/>
        <Rectangle Canvas.Left="450" Canvas.Top="475" Width="15" Height="45" Fill="#AA3333" Stroke="#CC5555" StrokeThickness="1" RadiusX="2" RadiusY="2"/>
        <Rectangle Canvas.Left="540" Canvas.Top="475" Width="15" Height="45" Fill="#AA3333" Stroke="#CC5555" StrokeThickness="1" RadiusX="2" RadiusY="2"/>
    </Canvas>
</UserControl>
