<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Msfs.ControllerVisualizer.Converters;assembly=Msfs.ControllerVisualizer">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="ControllerStyles.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- Rudder-specific shape styles -->
			<Style x:Key="RudderChassisRectangleStyle" TargetType="Rectangle" BasedOn="{StaticResource BasePanelStyle}">
				<Setter Property="Opacity" Value="0.55" />
			</Style>

			<Style x:Key="PedalLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelCenterStyle}" />

			<Style x:Key="RudderAxisBindingStyle" TargetType="TextBlock" BasedOn="{StaticResource BindingCenterStyle}">
				<Setter Property="Width" Value="200" />
			</Style>

			<Style x:Key="PedalControlLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource PedalLabelStyle}">
				<Setter Property="TextAlignment" Value="Center" />
				<Setter Property="Width" Value="240" />
			</Style>

			<Style x:Key="PedalControlBindingStyle" TargetType="TextBlock" BasedOn="{StaticResource RudderAxisBindingStyle}">
				<Setter Property="Width" Value="240" />
				<Setter Property="TextTrimming" Value="CharacterEllipsis" />
			</Style>
		</ResourceDictionary>
	</UserControl.Resources>

	<Grid>
		<Canvas Width="1200" Height="650" HorizontalAlignment="Center" VerticalAlignment="Center">
			<!-- Main rudder pedal chassis -->
			<Canvas Canvas.Left="110" Canvas.Top="120">

				<!-- Left pedal assembly -->
				<Canvas Canvas.Left="70" Canvas.Top="95">
					<Rectangle Width="240" Height="210" Style="{StaticResource RudderChassisRectangleStyle}" />
					<Polygon Points="25,40 120,10 215,40 200,170 40,170"
                             Fill="{StaticResource PanelFillBrush}" Stroke="{StaticResource StrokeBrush}" StrokeThickness="1.2" Opacity="0.7" />
					<TextBlock Text="Left Toe Brake" Style="{StaticResource PedalControlLabelStyle}" Canvas.Left="0" Canvas.Top="174" />
					<TextBlock Style="{StaticResource PedalControlBindingStyle}" Canvas.Left="0" Canvas.Top="192"
                               Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_L-Axis_X}"
                               ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_X}" />
				</Canvas>

				<!-- Right pedal assembly -->
				<Canvas Canvas.Left="670" Canvas.Top="95">
					<Rectangle Width="240" Height="210" Style="{StaticResource RudderChassisRectangleStyle}" />
					<Polygon Points="25,40 120,10 215,40 200,170 40,170"
                             Fill="{StaticResource PanelFillBrush}" Stroke="{StaticResource StrokeBrush}" StrokeThickness="1.2" Opacity="0.7" />
					<TextBlock Text="Right Toe Brake" Style="{StaticResource PedalControlLabelStyle}" Canvas.Left="0" Canvas.Top="174" />
					<TextBlock Style="{StaticResource PedalControlBindingStyle}" Canvas.Left="0" Canvas.Top="192"
                               Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_L-Axis_Y}"
                               ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_Y}" />
				</Canvas>

				<!-- Center rudder rotation indicator -->
				<Canvas Canvas.Left="350" Canvas.Top="58" Width="280" Height="260">
					<Ellipse Width="220" Height="220" Canvas.Left="30" Canvas.Top="10" Style="{StaticResource BaseEllipseStyle}" />

					<TextBlock Text="Rudder Axis" Style="{StaticResource PedalLabelStyle}" Width="220" TextAlignment="Center" Canvas.Left="30" Canvas.Top="102" />
					<TextBlock Style="{StaticResource RudderAxisBindingStyle}" Width="220" Canvas.Left="30" Canvas.Top="122"
                               Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_R-Axis_Z}"
                               ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_R-Axis_Z}" />
				</Canvas>
			</Canvas>
		</Canvas>
	</Grid>
</UserControl>
