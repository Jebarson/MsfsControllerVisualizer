<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Msfs.ControllerVisualizer.Converters;assembly=MSFSControllerVisualizer">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ControllerStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Controller-specific brushes -->
            <SolidColorBrush x:Key="BlueFillBrush" Color="#4A90E2" />
            <SolidColorBrush x:Key="RedFillBrush" Color="#E24A4A" />

            <!-- Override truncation length for Bravo visuals -->
            <converters:JoystickButtonTruncateConverter x:Key="JoystickButtonTruncateConverter" MaxLength="18" />

            <!-- Dial / indicator styles -->
            <Style x:Key="DialStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseEllipseStyle}">
                <Setter Property="Width" Value="45" />
                <Setter Property="Height" Value="45" />
            </Style>

            <Style x:Key="GearIndicatorStyle" TargetType="Ellipse">
                <Setter Property="Width" Value="20" />
                <Setter Property="Height" Value="20" />
                <Setter Property="Fill" Value="{StaticResource BindingTextBrush}" />
                <Setter Property="Opacity" Value="0.4" />
                <Setter Property="Stroke" Value="{StaticResource StrokeBrush}" />
                <Setter Property="StrokeThickness" Value="1" />
            </Style>

            <!-- Lever styles -->
            <Style x:Key="ThrottleLeverStyle" TargetType="Rectangle" BasedOn="{StaticResource BasePanelStyle}">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="80" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,5,0,0" />
                <Setter Property="Opacity" Value="1" />
            </Style>

            <Style x:Key="GrayLeverStyle" TargetType="Rectangle" BasedOn="{StaticResource ThrottleLeverStyle}">
                <Setter Property="Fill" Value="{StaticResource PanelFillBrush}" />
                <Setter Property="Opacity" Value="0.6" />
            </Style>

            <Style x:Key="BlackLeverStyle" TargetType="Rectangle" BasedOn="{StaticResource ThrottleLeverStyle}">
                <Setter Property="Fill" Value="{StaticResource BlackFillBrush}" />
            </Style>

            <Style x:Key="BlueLeverStyle" TargetType="Rectangle" BasedOn="{StaticResource ThrottleLeverStyle}">
                <Setter Property="Fill" Value="{StaticResource BlueFillBrush}" />
            </Style>

            <Style x:Key="RedLeverStyle" TargetType="Rectangle" BasedOn="{StaticResource ThrottleLeverStyle}">
                <Setter Property="Fill" Value="{StaticResource RedFillBrush}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Canvas Width="1200" Height="700" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- TOP AUTOPILOT PANEL -->
            <Canvas x:Name="AutopilotPanelCanvas" Canvas.Left="200" Canvas.Top="10">
                <Rectangle Width="990" Height="150" Style="{StaticResource BasePanelStyle}" />

                <!-- LEFT DIAL (5-position rotary selector) - Clockwise from 17 (bottom) to 21 (top) -->
                <Canvas Canvas.Left="100" Canvas.Top="50">
                    <Ellipse Style="{StaticResource DialStyle}" />

                    <!-- IAS (17) - Bottom (6 o'clock) -->
                    <Line X1="22.5" Y1="45" X2="22.5" Y2="70" Style="{StaticResource BaseLineStyle}" />
                    <TextBlock Text="17-IAS" Style="{StaticResource LabelCenterStyle}" Canvas.Left="10" Canvas.Top="62" />
                    <TextBlock Style="{StaticResource BindingCenterStyle}" Canvas.Left="-25" Canvas.Top="70"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_17}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_17}" />

                    <!-- CRS (18) - Bottom Left (7-8 o'clock) -->
                    <Line X1="7" Y1="37" X2="-18" Y2="52" Style="{StaticResource BaseLineStyle}" />
                    <TextBlock Text="18-CRS" Style="{StaticResource LabelRightStyle}" Canvas.Left="-75" Canvas.Top="42" />
                    <TextBlock Style="{StaticResource BindingRightStyle}" Canvas.Left="-105" Canvas.Top="50"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_18}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_18}" />

                    <!-- HDG (19) - Left (9 o'clock) -->
                    <Line X1="0" Y1="22.5" X2="-25" Y2="22.5" Style="{StaticResource BaseLineStyle}" />
                    <TextBlock Text="19-HDG" Style="{StaticResource LabelRightStyle}" Canvas.Left="-75" Canvas.Top="9" />
                    <TextBlock Style="{StaticResource BindingRightStyle}" Canvas.Left="-105" Canvas.Top="17"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_19}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_19}" />

                    <!-- V/S (20) - Top Left (10-11 o'clock) -->
                    <Line X1="7" Y1="8" X2="-18" Y2="-7" Style="{StaticResource BaseLineStyle}" />
                    <TextBlock Text="20-V/S" Style="{StaticResource LabelRightStyle}" Canvas.Left="-75" Canvas.Top="-23" />
                    <TextBlock Style="{StaticResource BindingRightStyle}" Canvas.Left="-105" Canvas.Top="-15"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_20}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_20}" />

                    <!-- ALT (21) - Top (12 o'clock) -->
                    <Line X1="22.5" Y1="0" X2="22.5" Y2="-25" Style="{StaticResource BaseLineStyle}" />
                    <TextBlock Text="21-ALT" Style="{StaticResource LabelCenterStyle}" Canvas.Left="10" Canvas.Top="-48" />
                    <TextBlock Style="{StaticResource BindingCenterStyle}" Canvas.Left="-25" Canvas.Top="-40"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_21}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_21}" />
                </Canvas>

                <!-- CENTER PUSH BUTTONS (1-7) -->
                <!-- Button 1: HDG -->
                <StackPanel Orientation="Vertical" Canvas.Left="170" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="1" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="HDG" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_1}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_1}" />
                </StackPanel>

                <!-- Button 2: NAV -->
                <StackPanel Orientation="Vertical" Canvas.Left="250" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="2" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="NAV" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_2}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_2}" />
                </StackPanel>

                <!-- Button 3: APR -->
                <StackPanel Orientation="Vertical" Canvas.Left="330" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="3" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="APR" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_3}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_3}" />
                </StackPanel>

                <!-- Button 4: REV -->
                <StackPanel Orientation="Vertical" Canvas.Left="410" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="4" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="REV" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_4}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_4}" />
                </StackPanel>

                <!-- Button 5: ALT -->
                <StackPanel Orientation="Vertical" Canvas.Left="490" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="5" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="ALT" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_5}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_5}" />
                </StackPanel>

                <!-- Button 6: V/S -->
                <StackPanel Orientation="Vertical" Canvas.Left="570" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="6" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="V/S" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_6}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_6}" />
                </StackPanel>

                <!-- Button 7: IAS -->
                <StackPanel Orientation="Vertical" Canvas.Left="650" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="7" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="IAS" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_7}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_7}" />
                </StackPanel>

                <!-- RIGHT KNOB (Buttons 14 - left, 15 - right) with rotation arrows -->
                <Canvas Canvas.Left="770" Canvas.Top="50">
                    <Ellipse Style="{StaticResource DialStyle}" />

                    <!-- Semicircular arc with arrows inside the knob -->
                    <Path Canvas.Left="7.5" Canvas.Top="8" Data="M 0 15 A 15 15 0 0 1 30 15"
                            Style="{StaticResource AxisPathStyle}" />
                    <Polygon Points="8.5,32 6.5,27 11,27" Style="{StaticResource AxisPolygonStyle}" />
                    <Polygon Points="37.5,32 35,27 40,26" Style="{StaticResource AxisPolygonStyle}" />

                    <!--Button 14 label (left)-->
                    <StackPanel Canvas.Left="-50" Canvas.Top="50">
                        <TextBlock Text="14" Style="{StaticResource LabelRightStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}" HorizontalAlignment="Right"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_14}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_14}" />
                    </StackPanel>

                    <!--Button 13 label (right)-->
                    <StackPanel Canvas.Left="40" Canvas.Top="50">
                        <TextBlock Text="13" Style="{StaticResource BaseLabelStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_13}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_13}" />
                    </StackPanel>
                </Canvas>

                <!-- Button 8: AUTO PILOT -->
                <StackPanel Orientation="Vertical" Canvas.Left="850" Canvas.Top="60">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="8" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Text="A/P" Style="{StaticResource LabelCenterStyle}" />
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_8}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_8}" />
                </StackPanel>
            </Canvas>

            <!-- LEFT SIDE - LANDING GEAR SECTION -->
            <Canvas x:Name="GearCanvas" Canvas.Left="30" Canvas.Top="180">
                <Rectangle Width="150" Height="210" Style="{StaticResource BasePanelStyle}" />

                <!-- Gear Indicator -->
                <Canvas Canvas.Left="45" Canvas.Top="15" Width="60" Height="70">
                    <!-- N - Nose -->
                    <Ellipse Style="{StaticResource GearIndicatorStyle}" Canvas.Left="20" Canvas.Top="5" />
                    <TextBlock Text="N" Style="{StaticResource BaseLabelStyle}" Canvas.Left="26" Canvas.Top="8" />

                    <!-- L - Left -->
                    <Ellipse Style="{StaticResource GearIndicatorStyle}" Canvas.Left="-5" Canvas.Top="33" />
                    <TextBlock Text="L" Style="{StaticResource BaseLabelStyle}" Canvas.Left="1" Canvas.Top="36" />

                    <!-- R - Right -->
                    <Ellipse Style="{StaticResource GearIndicatorStyle}" Canvas.Left="45" Canvas.Top="33" />
                    <TextBlock Text="R" Style="{StaticResource BaseLabelStyle}" Canvas.Left="52" Canvas.Top="36" />

                    <TextBlock Text="GEAR" Style="{StaticResource SectionLabelStyle}" Canvas.Left="15" Canvas.Top="25" />
                </Canvas>

                <!-- Gear buttons - vertically stacked -->
                <StackPanel Canvas.Left="30" Canvas.Top="80">
                    <!-- Button 31: Gear Up -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                        <Grid Width="26" Height="26">
                            <Ellipse Style="{StaticResource StandardButtonStyle}" />
                            <TextBlock Text="31" Style="{StaticResource ButtonNumberStyle}" />
                        </Grid>
                        <TextBlock Text="UP" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_31}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_31}" />
                    </StackPanel>

                    <!-- Button 32: Gear Down -->
                    <StackPanel Orientation="Vertical">
                        <Grid Width="26" Height="26">
                            <Ellipse Style="{StaticResource StandardButtonStyle}" />
                            <TextBlock Text="32" Style="{StaticResource ButtonNumberStyle}" />
                        </Grid>
                        <TextBlock Text="DOWN" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_32}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_32}" />
                    </StackPanel>
                </StackPanel>
            </Canvas>

            <!-- CENTER - TOGGLE SWITCHES (34-47: 7 switches with up/down) -->
            <Canvas x:Name="ToggleSwitchesCanvas" Canvas.Left="200" Canvas.Top="180">
                <Rectangle Width="850" Height="135" Style="{StaticResource BasePanelStyle}" />

                <UniformGrid Columns="7" Canvas.Left="25" Canvas.Top="25" Width="800" Height="100">
                    <!-- Switch 1: 34 (up), 35 (down) -->
                    <StackPanel>
                        <TextBlock Text="34" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_34}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_34}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="35" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_35}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_35}" />
                    </StackPanel>

                    <!-- Switch 2: 36 (up), 37 (down) -->
                    <StackPanel>
                        <TextBlock Text="36" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_36}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_36}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="37" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_37}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_37}" />
                    </StackPanel>

                    <!-- Switch 3: 38 (up), 39 (down) -->
                    <StackPanel>
                        <TextBlock Text="38" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_38}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_38}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="39" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_39}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_39}" />
                    </StackPanel>

                    <!-- Switch 4: 40 (up), 41 (down) -->
                    <StackPanel>
                        <TextBlock Text="40" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_40}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_40}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="41" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_41}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_41}" />
                    </StackPanel>

                    <!-- Switch 5: 42 (up), 43 (down) -->
                    <StackPanel>
                        <TextBlock Text="42" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_42}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_42}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="43" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_43}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_43}" />
                    </StackPanel>

                    <!-- Switch 6: 44 (up), 45 (down) -->
                    <StackPanel>
                        <TextBlock Text="44" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_44}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_44}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="45" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_45}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_45}" />
                    </StackPanel>

                    <!-- Switch 7: 46 (up), 47 (down) -->
                    <StackPanel>
                        <TextBlock Text="46" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_46}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_46}" />
                        <Rectangle Style="{StaticResource ToggleSwitchStyle}" />
                        <TextBlock Text="47" Style="{StaticResource ButtonNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_47}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_47}" />
                    </StackPanel>
                </UniformGrid>
            </Canvas>

            <!-- RIGHT SIDE - FLAPS LEVER -->
            <Canvas x:Name="FlapsCanvas" Canvas.Left="1070" Canvas.Top="180">
                <Rectangle Width="120" Height="210" Style="{StaticResource BasePanelStyle}" />
                <TextBlock Text="FLAPS" Style="{StaticResource SectionLabelStyle}" Canvas.Left="45" Canvas.Top="5" />

                <!-- Flaps buttons - vertically stacked -->
                <StackPanel Canvas.Left="20" Canvas.Top="35">
                    <!-- Button 16: Flaps Up -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                        <Grid Width="26" Height="26">
                            <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                            <TextBlock Text="16" Style="{StaticResource WhiteButtonNumberStyle}" />
                        </Grid>
                        <TextBlock Text="UP" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_16}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_16}" />
                    </StackPanel>

                    <!-- Button 15: Flaps Down -->
                    <StackPanel Orientation="Vertical">
                        <Grid Width="26" Height="26">
                            <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                            <TextBlock Text="15" Style="{StaticResource WhiteButtonNumberStyle}" />
                        </Grid>
                        <TextBlock Text="DOWN" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_15}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_15}" />
                    </StackPanel>
                </StackPanel>
            </Canvas>

            <!-- BOTTOM - THROTTLE QUADRANT -->
            <Canvas x:Name="ThrottleQuadrantCanvas" Canvas.Left="200" Canvas.Top="335">
                <Rectangle Width="850" Height="210" Style="{StaticResource BasePanelStyle}" />

                <!-- 7 Levers: Trim Wheel + 6 Throttle Levers with colored knobs -->
                <Grid Canvas.Left="25" Canvas.Top="40" Width="800" Height="150">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Trim Wheel (GRAY LEVER) -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Trim Wheel" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_22}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_22}" />
                        <Rectangle Style="{StaticResource GrayLeverStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_23}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_23}" />
                    </StackPanel>

                    <!-- Throttle 1 (BLACK) -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Throttle 1" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_Y}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_Y}" />
                        <Rectangle Style="{StaticResource BlackLeverStyle}" />
                    </StackPanel>

                    <!-- Throttle 2 (BLACK) -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Throttle 2" Style="{StaticResource LabelCenterStyle}" />
                        <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_X}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_L-Axis_X}" />
                        <Rectangle Style="{StaticResource BlackLeverStyle}" />
                    </StackPanel>

