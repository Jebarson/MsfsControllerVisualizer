<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Msfs.ControllerVisualizer.Converters;assembly=MSFSControllerVisualizer">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ControllerStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Alpha-specific brushes -->
            <SolidColorBrush x:Key="AlphaRedFillBrush" Color="#C0392B" />

            <!-- Base Ellipse sizes (use shared BaseEllipseStyle) -->
            <Style x:Key="GripEllipseStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseEllipseStyle}">
                <Setter Property="Width" Value="240" />
                <Setter Property="Height" Value="340" />
            </Style>

            <Style x:Key="HatEllipseStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseEllipseStyle}">
                <Setter Property="Width" Value="60" />
                <Setter Property="Height" Value="60" />
            </Style>

            <Style x:Key="CenterHubEllipseStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseEllipseStyle}">
                <Setter Property="Width" Value="300" />
                <Setter Property="Height" Value="190" />
            </Style>

            <Style x:Key="IgnitionDialEllipseStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseEllipseStyle}">
                <Setter Property="Width" Value="120" />
                <Setter Property="Height" Value="120" />
            </Style>

            <!-- Switch panel sizing -->
            <Style x:Key="SwitchPanelRectangleStyle" TargetType="Rectangle" BasedOn="{StaticResource BasePanelStyle}">
                <Setter Property="Width" Value="480" />
                <Setter Property="Height" Value="270" />
            </Style>

            <!-- Button color variants -->
            <Style x:Key="RedButtonStyle" TargetType="Ellipse" BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Fill" Value="{StaticResource AlphaRedFillBrush}" />
            </Style>

            <!-- Text variants -->
            <Style x:Key="RedButtonNumberStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonNumberStyle}">
                <Setter Property="Foreground" Value="White" />
            </Style>

            <Style x:Key="DirectionLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseLabelStyle}">
                <Setter Property="FontSize" Value="9" />
            </Style>

            <Style x:Key="SwitchNumberStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseLabelStyle}">
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,2,0,2" />
            </Style>

            <Style x:Key="AxisLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseLabelStyle}">
                <Setter Property="FontWeight" Value="Normal" />
            </Style>

            <Style x:Key="IgnitionLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseLabelStyle}" />

            <!-- Binding text variants -->
            <Style x:Key="DirectionBindingStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseBindingTextStyle}">
                <Setter Property="MinWidth" Value="45" />
            </Style>

            <Style x:Key="AxisBindingStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseBindingTextStyle}">
                <Setter Property="TextAlignment" Value="Center" />
            </Style>

            <Style x:Key="IgnitionBindingStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseBindingTextStyle}">
                <Setter Property="MinWidth" Value="75" />
            </Style>

            <!-- Switch Styles -->
            <Style x:Key="MasterSwitchStyle" TargetType="Rectangle" BasedOn="{StaticResource BaseSwitchStyle}">
                <Setter Property="Fill" Value="#8B0000" />
            </Style>

            <Style x:Key="AvionicsSwitchStyle" TargetType="Rectangle" BasedOn="{StaticResource BaseSwitchStyle}">
                <Setter Property="Fill" Value="White" />
            </Style>

            <Style x:Key="LightSwitchStyle" TargetType="Rectangle" BasedOn="{StaticResource BaseSwitchStyle}">
                <Setter Property="Height" Value="32" />
                <Setter Property="Fill" Value="{StaticResource PanelFillBrush}" />
                <Setter Property="Opacity" Value="0.5" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Canvas Width="1200" Height="650" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- LEFT YOKE GRIP ASSEMBLY -->
            <Canvas x:Name="LeftGripCanvas" Canvas.Left="80" Canvas.Top="20">
                <Ellipse Style="{StaticResource GripEllipseStyle}" />

                <!-- POV Hat Switch -->
                <Canvas Width="180" Height="180" Canvas.Left="30" Canvas.Top="10">
                    <Ellipse Canvas.Left="60" Canvas.Top="60" Style="{StaticResource HatEllipseStyle}" />

                    <!-- Hat Direction Tick Marks (inside dial) -->
                    <Line X1="90" Y1="65" X2="90" Y2="72" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="107" Y1="73" X2="103" Y2="77" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="115" Y1="90" X2="108" Y2="90" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="107" Y1="107" X2="103" Y2="103" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="90" Y1="115" X2="90" Y2="108" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="73" Y1="107" X2="77" Y2="103" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="65" Y1="90" X2="72" Y2="90" Style="{StaticResource TickMarkStyle}" />
                    <Line X1="73" Y1="73" X2="77" Y2="77" Style="{StaticResource TickMarkStyle}" />

                    <!-- Hat Direction Labels (close to dial) -->
                    <TextBlock Text="U" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="86" Canvas.Top="50" />
                    <TextBlock Text="U-R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="113" Canvas.Top="58" />
                    <TextBlock Text="R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="122" Canvas.Top="84" />
                    <TextBlock Text="D-R" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="113"
                            Canvas.Top="112" />
                    <TextBlock Text="D" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="86" Canvas.Top="122" />
                    <TextBlock Text="D-L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="46" Canvas.Top="112" />
                    <TextBlock Text="L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="42" Canvas.Top="84" />
                    <TextBlock Text="U-L" Style="{StaticResource DirectionLabelStyle}" Canvas.Left="46" Canvas.Top="58" />


                    <!-- Hat Direction Bindings (at end of half-length pointer lines) -->
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Up}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Up}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="67" Canvas.Top="33" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_UpRight}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_UpRight}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="122" Canvas.Top="52" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Right}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Right}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="137" Canvas.Top="84" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_DownRight}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_DownRight}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="122" Canvas.Top="112" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Down}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Down}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="67" Canvas.Top="137" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_DownLeft}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_DownLeft}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="15" Canvas.Top="112" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Left}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Left}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="0" Canvas.Top="84" />
                    <TextBlock
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Pov_Up_Left}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Pov_Up_Left}"
                            Style="{StaticResource DirectionBindingStyle}" Canvas.Left="15" Canvas.Top="52" />
                </Canvas>

                <!-- Button 1: Switch -->
                <StackPanel Orientation="Horizontal" Canvas.Left="210" Canvas.Top="40">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="1" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingRightStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_1}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_1}" />
                </StackPanel>

                <!-- Button 2: Switch -->
                <StackPanel Canvas.Left="180" Canvas.Top="135">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="2" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_2}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_2}" />
                </StackPanel>

                <!-- Button 6: Trim Up (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="60" Canvas.Top="190">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="6" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_6}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_6}" />
                </StackPanel>

                <!-- Button 5: Trim Down (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="60" Canvas.Top="245">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="5" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_5}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_5}" />
                </StackPanel>

                <!-- Button 8: Rudder Trim Right (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="140" Canvas.Top="190">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="8" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_8}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_8}" />
                </StackPanel>

                <!-- Button 7: Rudder Trim Left (Yoke Left) -->
                <StackPanel Orientation="Vertical" Canvas.Left="140" Canvas.Top="245">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="7" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_7}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_7}" />
                </StackPanel>
            </Canvas>

            <!-- CENTER HUB WITH AXIS INDICATORS -->
            <Canvas x:Name="CenterHubCanvas" Canvas.Left="450" Canvas.Top="95">
                <Ellipse Style="{StaticResource CenterHubEllipseStyle}" />

                <!-- Axis Display Area -->
                <Canvas Width="280" Height="190" Canvas.Top="5" Canvas.Left="10">
                    <!-- X Axis (Roll) Semicircle Indicator -->
                    <Path Canvas.Left="50" Canvas.Top="60" Data="M 0 50 A 50 50 0 0 1 100 50"
                            Style="{StaticResource AxisPathStyle}" />
                    <Polygon Points="50,120 45,110 55,110" Style="{StaticResource AxisPolygonStyle}" />
                    <Polygon Points="150,120 145,110 155,110" Style="{StaticResource AxisPolygonStyle}" />
                    <TextBlock Text="X Axis (Roll)" Style="{StaticResource AxisLabelStyle}" Canvas.Left="70"
                            Canvas.Top="80" />
                    <TextBlock Style="{StaticResource AxisBindingStyle}" Canvas.Left="60" Canvas.Top="95" Width="80"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter},ConverterParameter=Joystick_L-Axis_X}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter},ConverterParameter=Joystick_L-Axis_X}" />

                    <!-- Y Axis (Pitch) Vertical Arrow Indicator -->
                    <Line X1="220" Y1="40" X2="220" Y2="130" Style="{StaticResource AxisLineStyle}" />
                    <Polygon Points="220,30 215,40 225,40" Style="{StaticResource AxisPolygonStyle}" />
                    <Polygon Points="220,140 215,130 225,130" Style="{StaticResource AxisPolygonStyle}" />
                    <TextBlock Text="Y Axis (Pitch)" Style="{StaticResource AxisLabelStyle}" Canvas.Left="190"
                            Canvas.Top="80" />
                    <TextBlock Style="{StaticResource AxisBindingStyle}" Canvas.Left="180" Canvas.Top="95" Width="80"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter},ConverterParameter=Joystick_L-Axis_Y}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter},ConverterParameter=Joystick_L-Axis_Y}" />
                </Canvas>
            </Canvas>

            <!-- RIGHT YOKE GRIP ASSEMBLY -->
            <Canvas x:Name="RightGripCanvas" Canvas.Left="840" Canvas.Top="20">
                <Ellipse Style="{StaticResource GripEllipseStyle}" />

                <!-- Button 3: POV Hat Down -->
                <StackPanel Canvas.Left="-25" Canvas.Top="105">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource WhiteButtonStyle}" />
                        <TextBlock Text="3" Style="{StaticResource WhiteButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingRightStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_3}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_3}" />
                </StackPanel>

                <!-- Button 4: Smoke / Special -->
                <StackPanel Canvas.Left="130" Canvas.Top="55">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource RedButtonStyle}" />
                        <TextBlock Text="4" Style="{StaticResource RedButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingLeftStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_4}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_4}" />
                </StackPanel>

                <!-- Button 11: Rudder Trim Left (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="30" Canvas.Top="170">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="11" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_11}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_11}" />
                </StackPanel>

                <!-- Button 12: Rudder Trim Right (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="130" Canvas.Top="170">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="12" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_12}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_12}" />
                </StackPanel>

                <!-- Button 9: Trim Down (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="30" Canvas.Top="245">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="9" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_9}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_9}" />
                </StackPanel>

                <!-- Button 10: Trim Up (Yoke Right) -->
                <StackPanel Orientation="Vertical" Canvas.Left="130" Canvas.Top="245">
                    <Grid Width="26" Height="26">
                        <Ellipse Style="{StaticResource StandardButtonStyle}" />
                        <TextBlock Text="10" Style="{StaticResource ButtonNumberStyle}" />
                    </Grid>
                    <TextBlock Style="{StaticResource ButtonBindingBottomStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_10}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_10}" />
                </StackPanel>
            </Canvas>

            <!-- SWITCH PANEL ASSEMBLY -->
            <Canvas x:Name="SwitchPanelCanvas" Canvas.Left="260" Canvas.Top="360">
                <Rectangle Style="{StaticResource SwitchPanelRectangleStyle}" />

                <!-- Top Row: Master and Avionics Switches -->
                <UniformGrid Columns="4" Canvas.Left="15" Canvas.Top="5" Width="450" Height="135">

                    <!-- Master Alternator Switch (13-14) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="13 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_13}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_13}" />
                        <Rectangle Style="{StaticResource MasterSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="13 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_14}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_14}" />
                    </StackPanel>

                    <!-- Master Battery Switch (15-16) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="15 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_15}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_15}" />
                        <Rectangle Style="{StaticResource MasterSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="15 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_16}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_16}" />
                    </StackPanel>

                    <!-- Avionics Master 1 Switch (17-18) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="17 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_17}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_17}" />
                        <Rectangle Style="{StaticResource AvionicsSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="17 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_18}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_18}" />
                    </StackPanel>

                    <!-- Avionics Master 2 Switch (19-20) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="19 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_19}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_19}" />
                        <Rectangle Style="{StaticResource AvionicsSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="19 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="24"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_20}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_20}" />
                    </StackPanel>
                </UniformGrid>

                <!-- Bottom Row: Light Switches -->
                <UniformGrid Columns="5" Canvas.Left="5" Canvas.Top="145" Width="470" Height="120">

                    <!-- Beacon Lights Switch (21-22) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="21 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_21}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_21}" />
                        <Rectangle Style="{StaticResource LightSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="21 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_22}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_22}" />
                    </StackPanel>

                    <!-- Landing Lights Switch (23-24) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="23 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_23}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_23}" />
                        <Rectangle Style="{StaticResource LightSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="23 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_24}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_24}" />
                    </StackPanel>

                    <!-- Taxi Lights Switch (25-26) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="25 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_25}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_25}" />
                        <Rectangle Style="{StaticResource LightSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="25 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_26}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_26}" />
                    </StackPanel>

                    <!-- Nav Lights Switch (27-28) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="27 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_27}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_27}" />
                        <Rectangle Style="{StaticResource LightSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="27 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_28}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_28}" />
                    </StackPanel>

                    <!-- Strobe Lights Switch (29-30) -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="29 (ON)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_29}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_29}" />
                        <Rectangle Style="{StaticResource LightSwitchStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="29 (OFF)" Style="{StaticResource SwitchNumberStyle}" />
                        <TextBlock Style="{StaticResource SwitchBindingStyle}" MinHeight="20"
                                Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_30}"
                                ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_30}" />
                    </StackPanel>
                </UniformGrid>
            </Canvas>

            <!-- IGNITION / MAGNETO SWITCH ASSEMBLY (31-35) -->
            <Canvas x:Name="MagnetoDialCanvas" Canvas.Left="950" Canvas.Top="450">
                <Ellipse Style="{StaticResource IgnitionDialEllipseStyle}" />

                <!-- Ignition Position Tick Marks -->
                <Line X1="10" Y1="60" X2="20" Y2="60" Style="{StaticResource TickMarkStyle}" />
                <Line X1="21.7" Y1="27.9" X2="29.4" Y2="34.3" Style="{StaticResource TickMarkStyle}" />
                <Line X1="51.3" Y1="10.8" X2="53.1" Y2="20.6" Style="{StaticResource TickMarkStyle}" />
                <Line X1="85.0" Y1="16.7" X2="80.0" Y2="25.4" Style="{StaticResource TickMarkStyle}" />
                <Line X1="107.0" Y1="42.9" X2="97.6" Y2="46.3" Style="{StaticResource TickMarkStyle}" />

                <!-- OFF (31) - Left -->
                <StackPanel Canvas.Left="-80" Canvas.Top="50">
                    <TextBlock Text="OFF (31)" Style="{StaticResource IgnitionLabelStyle}" TextAlignment="Right" />
                    <TextBlock Style="{StaticResource IgnitionBindingStyle}" TextAlignment="Right"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_31}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_31}" />
                </StackPanel>

                <!-- R (32) - Top Left -->
                <StackPanel Canvas.Left="-70" Canvas.Top="-10">
                    <TextBlock Text="R (32)" Style="{StaticResource IgnitionLabelStyle}" TextAlignment="Right" />
                    <TextBlock Style="{StaticResource IgnitionBindingStyle}" TextAlignment="Right"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_32}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_32}" />
                </StackPanel>

                <!-- L (33) - Top -->
                <StackPanel Canvas.Left="25" Canvas.Top="-45">
                    <TextBlock Text="L (33)" Style="{StaticResource IgnitionLabelStyle}" TextAlignment="Center" />
                    <TextBlock Style="{StaticResource IgnitionBindingStyle}" TextAlignment="Center"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_33}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_33}" />
                </StackPanel>

                <!-- BOTH (34) - Top Right -->
                <StackPanel Canvas.Left="110" Canvas.Top="-20">
                    <TextBlock Text="BOTH (34)" Style="{StaticResource IgnitionLabelStyle}" />
                    <TextBlock Style="{StaticResource IgnitionBindingStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_34}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_34}" />
                </StackPanel>

                <!-- START (35) - Right -->
                <StackPanel Canvas.Left="125" Canvas.Top="25">
                    <TextBlock Text="START (35)" Style="{StaticResource IgnitionLabelStyle}" />
                    <TextBlock Style="{StaticResource IgnitionBindingStyle}"
                            Text="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonTruncateConverter}, ConverterParameter=Joystick_Button_35}"
                            ToolTip="{Binding Source={x:Null}, Converter={StaticResource JoystickButtonMappingConverter}, ConverterParameter=Joystick_Button_35}" />
                </StackPanel>
            </Canvas>

        </Canvas>
    </Grid>
</UserControl>
